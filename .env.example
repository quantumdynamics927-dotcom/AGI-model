# Environment Variables for Quantum Consciousness VAE

# System Configuration
TMT_OS_ENV=development
TMT_OS_HOST=localhost
TMT_OS_PORT=8000
LOG_LEVEL=INFO

# Security
JWT_SECRET=your_jwt_secret_here_change_in_production
ENCRYPTION_KEY=your_encryption_key_here_change_in_production

# Database
DATABASE_URL=postgresql://tmtos:password@localhost:5432/tmt_os_dev
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your_redis_password_here

# IBM Quantum
QISKIT_IBM_TOKEN=your_ibm_quantum_token_here
IBM_BACKEND=ibmq_qasm_simulator

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true

# API Keys
PINATA_JWT=your_pinata_jwt_here
PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here

# NFT Configuration
NFT_ENABLED=false
NFT_CONTRACT_ADDRESS=your_contract_address_here

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password_here

# Slack Integration (for notifications)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Performance Settings
MAX_WORKERS=4
BATCH_SIZE=32